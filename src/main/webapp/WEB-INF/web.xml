<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
    
    <!-- Session Config -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Authentication Filter -->
      <filter>
    <filter-name>AuthenticationFilter</filter-name>
    <filter-class>Control_Package.AuthenticationFilter</filter-class>
</filter>
    
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/admin_*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/CustomerServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/OrderServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/ItemServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/PaymentServlet</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/UserServlet</url-pattern>
    </filter-mapping>
    





    <servlet>
        <servlet-name>ItemCategoryServlet</servlet-name>
        <servlet-class>category_page_package.ItemCategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ItemCategoryServlet</servlet-name>
        <url-pattern>/customer/ItemCategoryServlet</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>ItemDetailsServlet</servlet-name>
        <servlet-class>Control_Package.ItemDetailsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ItemDetailsServlet</servlet-name>
        <url-pattern>/customer/ItemDetailsServlet</url-pattern>
    </servlet-mapping>
</web-app>